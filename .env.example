# ─────────────────────────────────────────────────────────────
# THE PERFECT FIXTURE — Environment Variables
# Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# ── AIS / Vessel Tracking ─────────────────────────────────────
# MarineTraffic API  → https://www.marinetraffic.com/en/ais-api-services
MARINETRAFFIC_API_KEY=your_marinetraffic_key_here

# AISHub (free tier available) → https://www.aishub.net/api
AISHUB_USERNAME=your_aishub_username_here

# VesselFinder API → https://www.vesselfinder.com/api
VESSELFINDER_API_KEY=your_vesselfinder_key_here

# ── Fuel / Oil Prices ─────────────────────────────────────────
# Ship & Bunker API → https://shipandbunker.com/api
SHIPANDBUNKER_API_KEY=your_shipandbunker_key_here

# Oil Price API (general crude/fuel) → https://oilpriceapi.com
OILPRICE_API_KEY=your_oilprice_key_here

# EIA (US Energy Info, free) → https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_key_here

# ── Baltic / Freight Indices ──────────────────────────────────
# Baltic Exchange API → https://www.balticexchange.com/en/data-services.html
BALTIC_API_KEY=your_baltic_exchange_key_here

# Freightos Baltic Index (FBX) → https://fbx.freightos.com
FREIGHTOS_API_KEY=your_freightos_key_here

# ── Port / Canal Data ─────────────────────────────────────────
# Sea-Intelligence / Port congestion data → https://www.sea-intelligence.com
SEA_INTELLIGENCE_API_KEY=your_sea_intelligence_key_here

# PortWatch (IMF, free) → https://portwatch.imf.org
# No key required, base URL only:
PORTWATCH_BASE_URL=https://portwatch.imf.org/api

# ── Weather / Routing ─────────────────────────────────────────
# OpenWeather Marine → https://openweathermap.org/api/ocean
OPENWEATHER_API_KEY=your_openweather_key_here

# StormGeo (professional marine routing) → https://www.stormgeo.com
STORMGEO_API_KEY=your_stormgeo_key_here

# ── Risk / Geopolitical ───────────────────────────────────────
# GardAlert (war risk zones) → https://www.gard.no
GARDALERT_API_KEY=your_gardalert_key_here

# ACLED Conflict Data (free) → https://acleddata.com/api/
ACLED_API_KEY=your_acled_key_here
ACLED_EMAIL=your_email_here

# ── Geocoding / Distance ──────────────────────────────────────
# SeaRoute / searoute-js handles sea distance calculations
# No key needed for the JS library version

# ── Currency (for forex rates) ────────────────────────────────
EXCHANGERATE_API_KEY=your_exchangerate_key_here

# ── Auth (if adding login) ────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
